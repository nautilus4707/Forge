# LLM Provider API Keys
# Configure at least one provider, or use Ollama for local inference (no API key required).
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_AI_API_KEY=your-key-here
GROQ_API_KEY=gsk_your-key-here
TOGETHER_API_KEY=your-key-here
DEEPSEEK_API_KEY=sk-your-key-here

# Local Inference
# Base URL of the Ollama instance. Defaults to http://localhost:11434.
FORGE_OLLAMA_HOST=http://localhost:11434

# Forge Runtime Settings
FORGE_DEBUG=false
FORGE_LOG_LEVEL=INFO
FORGE_DEFAULT_MODEL=claude-sonnet-4-20250514
FORGE_DEFAULT_PROVIDER=anthropic

# Security
# API key for authenticating requests to the Forge API. When unset, auth is disabled (local dev mode).
# Generate one with: python -c "import secrets; print(f'forge-{secrets.token_urlsafe(32)}')"
FORGE_API_KEY=
# Comma-separated list of allowed CORS origins. Defaults to http://localhost:3000.
FORGE_CORS_ORIGINS=http://localhost:3000
# Rate limit: max requests per minute per client IP.
FORGE_RATE_LIMIT_RPM=60
# Max request body size in bytes (default: 100 KB).
FORGE_MAX_REQUEST_SIZE=102400

# Tool Sandboxing
# Set to false to disable shell/python sandboxing (not recommended for production).
FORGE_SANDBOX_SHELL=true
FORGE_SANDBOX_PYTHON=true
# Comma-separated list of allowed shell commands when sandboxing is enabled.
FORGE_ALLOWED_SHELL_COMMANDS=ls,cat,head,tail,grep,find,wc,echo,pwd,date,whoami,curl,wget,git,python,pip,node,npm

# Docker / Redis
REDIS_PASSWORD=changeme
