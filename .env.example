# ── LLM Providers ──
# Set at least ONE provider key, or use Ollama for 100% free local inference.
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_AI_API_KEY=your-key-here
GROQ_API_KEY=gsk_your-key-here
TOGETHER_API_KEY=your-key-here
DEEPSEEK_API_KEY=sk-your-key-here

# ── Local Inference ──
# Point to your Ollama instance (local or on another machine like a Mac Mini).
OLLAMA_HOST=http://localhost:11434

# ── Forge Settings ──
FORGE_DEBUG=false
FORGE_LOG_LEVEL=INFO
FORGE_DEFAULT_MODEL=claude-sonnet-4-20250514
FORGE_DEFAULT_PROVIDER=anthropic
